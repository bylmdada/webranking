# Google Indexing API - Service Account JSON key (base64 encoded)
GOOGLE_SERVICE_ACCOUNT_KEY=

# IndexNow API key (generate a random string, e.g. uuid)
INDEXNOW_API_KEY=

# Optional: run specific modules only (comma-separated: visit,search,indexing,indexnow)
RUN_MODULES=visit,search,indexing,indexnow

# Optional: simulation speed profile (default or ci)
SIMULATION_PROFILE=default

# Optional: print intended actions without opening browsers or calling external APIs
DRY_RUN=false
